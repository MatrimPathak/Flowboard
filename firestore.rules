rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Chronicle Docs ────────────────────────────────────────────────────────
    // The browser client SDK (docs-firestore.ts) reads and writes these
    // subcollections directly. All other collections go through the server API
    // which uses firebase-admin and bypasses these rules entirely.
    match /workspaces/{workspaceId}/docs/{docId} {
      allow read, write: if request.auth != null;
    }
    match /workspaces/{workspaceId}/projects/{projectId}/docs/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Members ───────────────────────────────────────────────────────────────
    // All member writes (create, update, delete) go through firebase-admin via
    // the server API. Blocking client writes prevents any authenticated user
    // from directly inserting a member record or elevating their own role.
    match /members/{memberId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Legacy flat docs collection ───────────────────────────────────────────
    // Docs were migrated to workspace/project subcollections. Deny all access
    // to the old top-level collection so stale data cannot be read or written.
    match /docs/{docId} {
      allow read, write: if false;
    }

    // ── Everything else ───────────────────────────────────────────────────────
    // Workspaces, projects, tasks, sprints, versions, comments, worklogs, and
    // all other server-managed data. Clients may read (needed to render the UI)
    // but must never write directly — all mutations go through the server API.
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
